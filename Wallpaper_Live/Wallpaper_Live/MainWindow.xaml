<Window x:Class="WallpaperMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wallpaper Music Player" 
        Height="1080" Width="1920"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ВІДЕО (ОДНЕ ВІКНО) -->
        <Image x:Name="VideoImage" 
               Grid.Column="0"
               Stretch="UniformToFill" 
               HorizontalAlignment="Stretch" 
               VerticalAlignment="Stretch"/>

        <!-- ПАНЕЛЬ ВІДЛАДКИ (F12) -->
        <Grid x:Name="DebugPanel" Grid.Column="1" Background="#E6111111" Width="400" Visibility="Collapsed">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ЛОГИ -->
            <StackPanel Grid.Row="0" Margin="10">
                <TextBlock Text="SYSTEM LOGS" Foreground="#bd93f9" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border Background="#333" CornerRadius="5" Padding="5">
                    <RichTextBox x:Name="LogOutput" 
                                 Height="350" 
                                 Background="Transparent" BorderThickness="0" 
                                 Foreground="#EEE" FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True" Focusable="False"
                                 VerticalScrollBarVisibility="Auto">
                        <FlowDocument>
                            <Paragraph Margin="0">
                                <Run Text="--- SINGLE WINDOW MODE ---" Foreground="Cyan"/>
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Border>
            </StackPanel>

            <!-- ІНФОРМАЦІЙНІ ПАНЕЛІ -->
            <StackPanel Grid.Row="1" Margin="10,0,10,20">

                <!-- 1. МОНІТОР ЧАСУ -->
                <Border Background="#333" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="SYNC MONITOR" Foreground="#AAA" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="AUDIO: " Foreground="#8be9fd" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtAudioTime" Text="--:--" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="VIDEO: " Foreground="#ff79c6" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtVideoTime" Text="--:--" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>

                        <Separator Background="#555" Margin="0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DIFF : " Foreground="#bd93f9" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtDiff" Text="0.00s" Foreground="#50fa7b" FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 2. ДІАГНОСТИКА (ПОВНА) -->
                <Border Background="#333" CornerRadius="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="DIAGNOSTICS" Foreground="#AAA" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>

                        <!-- Процеси -->
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Processes: " Foreground="#f1fa8c" FontFamily="Consolas" Width="80"/>
                            <TextBlock x:Name="TxtProcessCount" Text="0" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Text=" (ID: " Foreground="Gray" FontFamily="Consolas"/>
                            <TextBlock x:Name="TxtProcessId" Text="0" Foreground="Gray" FontFamily="Consolas"/>
                            <TextBlock Text=")" Foreground="Gray" FontFamily="Consolas"/>
                        </StackPanel>

                        <!-- Вікна -->
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Win Count: " Foreground="#f1fa8c" FontFamily="Consolas" Width="80"/>
                            <TextBlock x:Name="TxtWindowCount" Text="0" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>

                        <Separator Background="#555" Margin="0,5"/>

                        <!-- Стан -->
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="State: " Foreground="#8be9fd" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtWindowState" Text="Normal" Foreground="White" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Visible: " Foreground="#8be9fd" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtVisibility" Text="Visible" Foreground="White" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Topmost: " Foreground="#8be9fd" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtTopmost" Text="False" Foreground="White" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Handle: " Foreground="#ff79c6" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtHandle" Text="0x000000" Foreground="White" FontFamily="Consolas" FontSize="10"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Size: " Foreground="#ff79c6" FontFamily="Consolas" Width="60"/>
                            <TextBlock x:Name="TxtRenderSize" Text="0x0" Foreground="White" FontFamily="Consolas" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>