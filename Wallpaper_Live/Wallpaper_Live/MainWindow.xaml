<Window x:Class="WallpaperMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wallpaper Music Player" 
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Loaded="Window_Loaded">

    <Grid>
        <!-- ВІДЕОПЛЕЄР -->
        <MediaElement x:Name="VideoPlayer" 
                      LoadedBehavior="Manual" 
                      Stretch="UniformToFill"
                      MediaEnded="VideoPlayer_MediaEnded"
                      MediaFailed="VideoPlayer_MediaFailed"
                      ScrubbingEnabled="True"/>

        <!-- ЛОГИ (Зліва) -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20">
            <Border Background="#CC000000" CornerRadius="5" Padding="10">
                <RichTextBox x:Name="LogOutput" 
                             Width="400" Height="250" 
                             Background="Transparent" BorderThickness="0" 
                             Foreground="#EEE" FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True" Focusable="False"
                             VerticalScrollBarVisibility="Hidden">
                    <FlowDocument>
                        <Paragraph Margin="0">
                            <Run Text="--- SYSTEM READY ---" Foreground="#bd93f9" FontWeight="Bold"/>
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </Border>
        </StackPanel>

        <!-- МОНІТОР ЧАСУ (Справа) -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
            <Border Background="#D0000000" CornerRadius="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="SYNC MONITOR (1080p)" Foreground="#AAA" FontSize="10" FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,5"/>

                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="AUDIO: " Foreground="#8be9fd" FontFamily="Consolas" Width="50"/>
                        <TextBlock x:Name="TxtAudioTime" Text="--:--" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="VIDEO: " Foreground="#ff79c6" FontFamily="Consolas" Width="50"/>
                        <TextBlock x:Name="TxtVideoTime" Text="--:--" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                    </StackPanel>

                    <Separator Background="#444" Margin="0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="DIFF : " Foreground="#bd93f9" FontFamily="Consolas" Width="50"/>
                        <TextBlock x:Name="TxtDiff" Text="0.00s" Foreground="#50fa7b" FontFamily="Consolas" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>