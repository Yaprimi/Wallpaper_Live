<Window x:Class="WallpaperMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Wallpaper Music Player" 
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ВІДЕОПЛЕЄР -->
        <vlc:VideoView x:Name="VideoPlayer" 
                       Grid.Column="0"
                       HorizontalAlignment="Stretch" 
                       VerticalAlignment="Stretch"/>

        <!-- ПАНЕЛЬ ВІДЛАДКИ (Прихована за замовчуванням) -->
        <Grid x:Name="DebugPanel" Grid.Column="1" Background="#222" Width="400" Visibility="Collapsed">

            <!-- ЛОГИ -->
            <StackPanel VerticalAlignment="Top" Margin="10">
                <TextBlock Text="SYSTEM LOGS" Foreground="#bd93f9" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border Background="#333" CornerRadius="5" Padding="5">
                    <RichTextBox x:Name="LogOutput" 
                                 Height="400" 
                                 Background="Transparent" BorderThickness="0" 
                                 Foreground="#EEE" FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True" Focusable="False"
                                 VerticalScrollBarVisibility="Auto">
                        <FlowDocument>
                            <Paragraph Margin="0">
                                <Run Text="--- DEBUG START (Press F12 to toggle) ---" Foreground="Gray"/>
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Border>
            </StackPanel>

            <!-- МОНІТОР ЧАСУ -->
            <StackPanel VerticalAlignment="Bottom" Margin="10,20">
                <Border Background="#333" CornerRadius="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="SYNC MONITOR" Foreground="#AAA" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="AUDIO: " Foreground="#8be9fd" FontFamily="Consolas" Width="50"/>
                            <TextBlock x:Name="TxtAudioTime" Text="--:--" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="VIDEO: " Foreground="#ff79c6" FontFamily="Consolas" Width="50"/>
                            <TextBlock x:Name="TxtVideoTime" Text="--:--" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>

                        <Separator Background="#555" Margin="0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DIFF : " Foreground="#bd93f9" FontFamily="Consolas" Width="50"/>
                            <TextBlock x:Name="TxtDiff" Text="0.00s" Foreground="#50fa7b" FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>